# MongoDB connection
MONGO_URL=mongodb://localhost:27017
DB_NAME=hudent_local

# JWT signing secret (use a long random string in real env)
JWT_SECRET=change-me-super-secret-local

# Enable demo seed at startup (creates demo studio + demo data)
DEMO_SEED=true

# Optional: credentials for demo admin user when DEMO_SEED=true
ADMIN_EMAIL=admin@dentalflow.it
ADMIN_PASSWORD=DentalFlow2026!

# CORS: frontend origins allowed to call backend directly
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
